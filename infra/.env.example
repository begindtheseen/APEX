# ─────────────────────────────────────────────────────────────────────────
# APEX self-hosted platform — environment
# Copy to `.env` and fill in. NEVER commit the real .env (it holds secrets).
#   cp .env.example .env && ./scripts/gen-secrets.sh
# ─────────────────────────────────────────────────────────────────────────

# Public domain the gateway answers on. For a real cert use a domain you own
# pointed at this box. For LAN-only testing use `localhost` (Caddy issues an
# internal cert) or a *.local name.
DOMAIN=apex.example.com

# Email Caddy uses for Let's Encrypt registration (recovery only).
ACME_EMAIL=you@example.com

# ── Postgres ──────────────────────────────────────────────────────────────
POSTGRES_DB=postgres
POSTGRES_PASSWORD=CHANGE_ME_postgres_superuser_password

# ── Shared JWT secret (GoTrue signs, PostgREST verifies) ──────────────────
# Must be the SAME value in both services. Generate with gen-secrets.sh.
JWT_SECRET=CHANGE_ME_min_32_char_random_secret

# ── Auth (GoTrue) ─────────────────────────────────────────────────────────
# Autoconfirm=true lets accounts work WITHOUT an SMTP server (good to start).
# Set up SMTP + flip these to false when you want email magic-links/verify.
GOTRUE_MAILER_AUTOCONFIRM=true
GOTRUE_DISABLE_SIGNUP=false
# Optional SMTP (leave blank until you wire a mail provider or self-host one):
GOTRUE_SMTP_HOST=
GOTRUE_SMTP_PORT=587
GOTRUE_SMTP_USER=
GOTRUE_SMTP_PASS=
GOTRUE_SMTP_SENDER_NAME=APEX
